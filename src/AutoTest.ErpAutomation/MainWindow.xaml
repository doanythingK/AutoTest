<Window x:Class="AutoTest.ErpAutomation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ERP 매출등록 자동화"
        Width="1120"
        Height="760"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#22313F" Padding="20,16">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding CheckChromeCommand}"
                            Content="Chrome 연결 확인"
                            Margin="0,0,8,0"
                            Padding="14,8" />
                    <Button Command="{Binding StartChromeCommand}"
                            Content="Chrome 실행"
                            Padding="14,8" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="ERP 매출등록 자동화"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ChromeStatus}"
                               Foreground="#DDE6ED"
                               Margin="0,6,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D5DCE3"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding SaveSettingsCommand}"
                                Content="설정 저장"
                                Padding="10,6" />
                        <TextBlock Text="입력값"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2A33" />
                    </DockPanel>

                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <TextBlock Text="수량" Margin="0,0,0,6" />
                        <TextBox Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,14,0,0">
                        <TextBlock Text="단가" Margin="0,0,0,6" />
                        <TextBox Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,14,0,0">
                        <TextBlock Text="거래처코드" Margin="0,0,0,6" />
                        <TextBox Text="{Binding ClientCode, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,14,0,0">
                        <TextBlock Text="계정코드(대변)" Margin="0,0,0,6" />
                        <TextBox Text="{Binding CreditAccountCode, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,14,0,0">
                        <TextBlock Text="거래일자" Margin="0,0,0,6" />
                        <DatePicker SelectedDate="{Binding TransactionDate}" Height="34" />
                    </StackPanel>

                    <Border Grid.Row="6"
                            Background="#F8FAFC"
                            BorderBrush="#D5DCE3"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12"
                            Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="예상 계산값" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ExpectedSupplyAmountText, StringFormat=공급가액: {0}}"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding ExpectedTaxAmountText, StringFormat=세액: {0}}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Expander Grid.Row="7"
                              Header="Chrome 연결 설정"
                              Margin="0,18,0,0"
                              IsExpanded="False">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Chrome 경로" Margin="0,0,0,6" />
                            <TextBox Text="{Binding ChromePath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32"
                                     VerticalContentAlignment="Center" />

                            <TextBlock Text="프로필 디렉터리" Margin="0,12,0,6" />
                            <TextBox Text="{Binding ChromeProfileDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32"
                                     VerticalContentAlignment="Center" />

                            <TextBlock Text="원격 디버깅 포트" Margin="0,12,0,6" />
                            <TextBox Text="{Binding RemoteDebuggingPortText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="32"
                                     VerticalContentAlignment="Center" />
                        </StackPanel>
                    </Expander>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D5DCE3"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,14">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Command="{Binding CancelAutomationCommand}"
                                Content="중지"
                                Margin="0,0,8,0"
                                Padding="16,9" />
                        <Button Command="{Binding RunAutomationCommand}"
                                Content="자동화 실행"
                                Padding="20,9" />
                    </StackPanel>
                        <StackPanel>
                            <TextBlock Text="실행 로그"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2A33" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#5D6B78"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                    </DockPanel>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Logs}"
                              BorderBrush="#D5DCE3"
                              BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="시간"
                                                Width="90"
                                                DisplayMemberBinding="{Binding TimeText}" />
                                <GridViewColumn Header="단계"
                                                Width="80"
                                                DisplayMemberBinding="{Binding Level}" />
                                <GridViewColumn Header="내용"
                                                Width="520"
                                                DisplayMemberBinding="{Binding Message}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem Content="{Binding StatusMessage}" />
        </StatusBar>
    </Grid>
</Window>
